{
  "__comment__": [
    "CodeChecker analyze configuration for the thesis padding-leak prototype.",
    "Usage: CodeChecker analyze compile_commands.json --config codechecker.json -o ./cc-results",
    "Then:  CodeChecker parse ./cc-results",
    "Or:    CodeChecker parse ./cc-results --export json -o results.json",
    "",
    "IMPORTANT: set PLUGIN_PATH below to the absolute path of your built .so,",
    "e.g.  /home/user/clang-tidy-tls-checks/build/SecurityMiscPlugin.so"
  ],
  "analyze": [
    "--analyzers", "clang-tidy",

    "--tidyargs",
    "-load __PLUGIN_PATH__ -checks=-*,security-misc-padding-boundary-leak,tls-cert-verify-disabled,tls-insecure-proto-method",

    "--jobs", "4",

    "--output", "./cc-results",

    "--analyzer-config",
    "clang-tidy:HeaderFilterRegex=.*"
  ],
  "parse": [
    "--trim-path-prefix", "."
  ]
}
